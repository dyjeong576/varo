FROM node:22-alpine AS base
WORKDIR /app
ENV NEXT_TELEMETRY_DISABLED=1

FROM base AS deps
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci

FROM base AS builder
ARG NEXT_PUBLIC_APP_NAME
ARG NEXT_PUBLIC_APP_TAGLINE
ARG NEXT_PUBLIC_APP_PUBLIC_URL
ARG NEXT_PUBLIC_APP_INTENDED_PRODUCTION_HOST
ARG NEXT_PUBLIC_APP_CANONICAL_HOST_STATUS
ARG NEXT_PUBLIC_API_BASE_URL
ARG NEXT_PUBLIC_APP_ENV
ENV NEXT_PUBLIC_APP_NAME=$NEXT_PUBLIC_APP_NAME
ENV NEXT_PUBLIC_APP_TAGLINE=$NEXT_PUBLIC_APP_TAGLINE
ENV NEXT_PUBLIC_APP_PUBLIC_URL=$NEXT_PUBLIC_APP_PUBLIC_URL
ENV NEXT_PUBLIC_APP_INTENDED_PRODUCTION_HOST=$NEXT_PUBLIC_APP_INTENDED_PRODUCTION_HOST
ENV NEXT_PUBLIC_APP_CANONICAL_HOST_STATUS=$NEXT_PUBLIC_APP_CANONICAL_HOST_STATUS
ENV NEXT_PUBLIC_API_BASE_URL=$NEXT_PUBLIC_API_BASE_URL
ENV NEXT_PUBLIC_APP_ENV=$NEXT_PUBLIC_APP_ENV
COPY --from=deps /app/node_modules ./node_modules
COPY frontend/ ./
RUN npm run build

FROM node:22-alpine AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
ENV NEXT_PUBLIC_APP_NAME=
ENV NEXT_PUBLIC_APP_TAGLINE=
ENV NEXT_PUBLIC_APP_PUBLIC_URL=
ENV NEXT_PUBLIC_APP_INTENDED_PRODUCTION_HOST=
ENV NEXT_PUBLIC_APP_CANONICAL_HOST_STATUS=
ENV NEXT_PUBLIC_API_BASE_URL=
ENV NEXT_PUBLIC_APP_ENV=
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public
EXPOSE 3000
CMD ["node", "server.js"]
