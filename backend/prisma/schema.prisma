generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                      String                     @id @default(uuid())
  email                   String                     @unique
  displayName             String?                    @map("display_name")
  authProvider            String                     @default("google") @map("auth_provider")
  createdAt               DateTime                   @default(now()) @map("created_at")
  profile                 UserProfile?
  sessions                Session[]
  reviewJobs              ReviewJob[]
  historyEntries          UserHistory[]
  communityPosts          CommunityPost[]
  communityComments       CommunityComment[]
  communityPostLikes      CommunityPostLike[]
  communityCommentLikes   CommunityCommentLike[]
  notifications           Notification[]
  notificationReads       NotificationRead[]
  notificationPreference  UserNotificationPreference?

  @@map("users")
}

model UserProfile {
  userId    String   @id @map("user_id")
  realName  String?  @map("real_name")
  gender    String?
  ageRange  String?  @map("age_range")
  country   String?
  city      String?
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Session {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  providerSubject String   @map("provider_subject")
  expiresAt       DateTime @map("expires_at")
  createdAt       DateTime @default(now()) @map("created_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Claim {
  id             String      @id @default(uuid())
  rawText        String      @map("raw_text")
  normalizedText String      @map("normalized_text")
  createdAt      DateTime    @default(now()) @map("created_at")
  reviewJobs     ReviewJob[]

  @@map("claims")
}

model ReviewJob {
  id                  String            @id @default(uuid())
  userId              String            @map("user_id")
  claimId             String            @map("claim_id")
  clientRequestId     String?           @map("client_request_id")
  status              String
  currentStage        String            @map("current_stage")
  searchedSourceCount Int               @default(0) @map("searched_source_count")
  processedSourceCount Int              @default(0) @map("processed_source_count")
  retryCount          Int               @default(0) @map("retry_count")
  lastErrorCode       String?           @map("last_error_code")
  queryRefinement     Json?             @map("query_refinement")
  handoffPayload      Json?             @map("handoff_payload")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  claim               Claim             @relation(fields: [claimId], references: [id], onDelete: Cascade)
  sources             Source[]
  evidenceSnippets    EvidenceSnippet[]
  historyEntries      UserHistory[]

  @@index([userId])
  @@index([claimId])
  @@unique([userId, clientRequestId])
  @@map("review_jobs")
}

model UserHistory {
  id         String    @id @default(uuid())
  userId     String    @map("user_id")
  reviewJobId String   @map("review_job_id")
  entryType  String    @map("entry_type")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewJob  ReviewJob @relation(fields: [reviewJobId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([reviewJobId, createdAt])
  @@index([entryType, createdAt])
  @@map("user_history")
}

model Source {
  id               String               @id @default(uuid())
  reviewJobId      String               @map("review_job_id")
  sourceProvider   String               @map("source_provider")
  sourceType       String               @map("source_type")
  publisherName    String?              @map("publisher_name")
  publishedAt      DateTime?            @map("published_at")
  canonicalUrl     String               @map("canonical_url")
  originalUrl      String               @map("original_url")
  rawTitle         String               @map("raw_title")
  rawSnippet       String?              @map("raw_snippet")
  normalizedHash   String               @map("normalized_hash")
  fetchStatus      String               @map("fetch_status")
  contentText      String?              @map("content_text")
  isDuplicate      Boolean              @default(false) @map("is_duplicate")
  duplicateGroupKey String?             @map("duplicate_group_key")
  originQueryIds   Json?                @map("origin_query_ids")
  relevanceTier    String?              @map("relevance_tier")
  relevanceReason  String?              @map("relevance_reason")
  retrievalBucket  String?              @map("retrieval_bucket")
  reviewJob        ReviewJob            @relation(fields: [reviewJobId], references: [id], onDelete: Cascade)
  evidenceSnippets EvidenceSnippet[]

  @@index([reviewJobId])
  @@index([sourceProvider])
  @@map("sources")
}

model EvidenceSnippet {
  id          String   @id @default(uuid())
  reviewJobId String   @map("review_job_id")
  sourceId    String   @map("source_id")
  snippetText String   @map("snippet_text")
  stance      String
  startOffset Int?     @map("start_offset")
  endOffset   Int?     @map("end_offset")
  reviewJob   ReviewJob @relation(fields: [reviewJobId], references: [id], onDelete: Cascade)
  source      Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([reviewJobId])
  @@index([sourceId])
  @@map("evidence_snippets")
}

model CommunityPost {
  id        String              @id @default(uuid())
  userId    String              @map("user_id")
  title     String
  content   String
  category  String
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments  CommunityComment[]
  likes     CommunityPostLike[]

  @@index([userId])
  @@index([createdAt])
  @@map("community_posts")
}

model CommunityComment {
  id        String        @id @default(uuid())
  postId    String        @map("post_id")
  userId    String        @map("user_id")
  parentCommentId String? @map("parent_comment_id")
  content   String
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  parentComment CommunityComment? @relation("CommunityCommentReplies", fields: [parentCommentId], references: [id], onDelete: Cascade)
  replies   CommunityComment[] @relation("CommunityCommentReplies")
  likes     CommunityCommentLike[]

  @@index([postId, createdAt])
  @@index([userId])
  @@index([parentCommentId])
  @@map("community_comments")
}

model CommunityPostLike {
  postId    String        @map("post_id")
  userId    String        @map("user_id")
  createdAt DateTime      @default(now()) @map("created_at")
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([userId])
  @@map("community_post_likes")
}

model CommunityCommentLike {
  commentId  String   @map("comment_id")
  userId     String   @map("user_id")
  createdAt  DateTime @default(now()) @map("created_at")
  comment    CommunityComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([commentId, userId])
  @@index([userId])
  @@map("community_comment_likes")
}

model Notification {
  id               String             @id @default(uuid())
  userId           String             @map("user_id")
  notificationType String             @map("notification_type")
  title            String
  body             String
  targetType       String             @map("target_type")
  targetId         String             @map("target_id")
  createdAt        DateTime           @default(now()) @map("created_at")
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  reads            NotificationRead[]

  @@index([userId, createdAt])
  @@index([targetType, targetId])
  @@map("notifications")
}

model NotificationRead {
  notificationId String       @map("notification_id")
  userId         String       @map("user_id")
  readAt         DateTime     @default(now()) @map("read_at")
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([notificationId, userId])
  @@index([userId, readAt])
  @@map("notification_reads")
}

model UserNotificationPreference {
  userId           String   @id @map("user_id")
  reviewCompleted  Boolean  @default(true) @map("review_completed")
  communityComment Boolean  @default(true) @map("community_comment")
  communityLike    Boolean  @default(true) @map("community_like")
  updatedAt        DateTime @updatedAt @map("updated_at")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_notification_preferences")
}
