generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String      @id @default(uuid())
  email        String      @unique
  displayName  String?     @map("display_name")
  authProvider String      @default("google") @map("auth_provider")
  createdAt    DateTime    @default(now()) @map("created_at")
  profile      UserProfile?
  sessions     Session[]
  reviewJobs   ReviewJob[]

  @@map("users")
}

model UserProfile {
  userId    String   @id @map("user_id")
  realName  String?  @map("real_name")
  gender    String?
  ageRange  String?  @map("age_range")
  country   String?
  city      String?
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model Session {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  providerSubject String   @map("provider_subject")
  expiresAt       DateTime @map("expires_at")
  createdAt       DateTime @default(now()) @map("created_at")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Claim {
  id             String      @id @default(uuid())
  rawText        String      @map("raw_text")
  normalizedText String      @map("normalized_text")
  createdAt      DateTime    @default(now()) @map("created_at")
  reviewJobs     ReviewJob[]

  @@map("claims")
}

model ReviewJob {
  id                  String            @id @default(uuid())
  userId              String            @map("user_id")
  claimId             String            @map("claim_id")
  clientRequestId     String?           @map("client_request_id")
  status              String
  currentStage        String            @map("current_stage")
  searchedSourceCount Int               @default(0) @map("searched_source_count")
  processedSourceCount Int              @default(0) @map("processed_source_count")
  retryCount          Int               @default(0) @map("retry_count")
  lastErrorCode       String?           @map("last_error_code")
  queryRefinement     Json?             @map("query_refinement")
  handoffPayload      Json?             @map("handoff_payload")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  claim               Claim             @relation(fields: [claimId], references: [id], onDelete: Cascade)
  sources             Source[]
  evidenceSnippets    EvidenceSnippet[]

  @@index([userId])
  @@index([claimId])
  @@unique([userId, clientRequestId])
  @@map("review_jobs")
}

model Source {
  id               String               @id @default(uuid())
  reviewJobId      String               @map("review_job_id")
  sourceType       String               @map("source_type")
  publisherName    String?              @map("publisher_name")
  publishedAt      DateTime?            @map("published_at")
  canonicalUrl     String               @map("canonical_url")
  originalUrl      String               @map("original_url")
  rawTitle         String               @map("raw_title")
  rawSnippet       String?              @map("raw_snippet")
  normalizedHash   String               @map("normalized_hash")
  fetchStatus      String               @map("fetch_status")
  contentText      String?              @map("content_text")
  isDuplicate      Boolean              @default(false) @map("is_duplicate")
  duplicateGroupKey String?             @map("duplicate_group_key")
  originQueryIds   Json?                @map("origin_query_ids")
  relevanceTier    String?              @map("relevance_tier")
  relevanceReason  String?              @map("relevance_reason")
  sourceCountryCode String?             @map("source_country_code")
  retrievalBucket  String?              @map("retrieval_bucket")
  domainRegistryId String?              @map("domain_registry_id")
  reviewJob        ReviewJob            @relation(fields: [reviewJobId], references: [id], onDelete: Cascade)
  domainRegistry   SourceDomainRegistry? @relation(fields: [domainRegistryId], references: [id], onDelete: SetNull)
  evidenceSnippets EvidenceSnippet[]

  @@index([reviewJobId])
  @@index([domainRegistryId])
  @@map("sources")
}

model SourceDomainRegistry {
  id           String   @id @default(uuid())
  domain       String
  countryCode  String   @map("country_code")
  languageCode String?  @map("language_code")
  sourceKind   String   @map("source_kind")
  usageRole    String   @map("usage_role")
  priority     Int      @default(100)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  sources      Source[]

  @@index([countryCode, usageRole, isActive])
  @@unique([domain, usageRole])
  @@map("source_domain_registry")
}

model EvidenceSnippet {
  id          String   @id @default(uuid())
  reviewJobId String   @map("review_job_id")
  sourceId    String   @map("source_id")
  snippetText String   @map("snippet_text")
  stance      String
  startOffset Int?     @map("start_offset")
  endOffset   Int?     @map("end_offset")
  reviewJob   ReviewJob @relation(fields: [reviewJobId], references: [id], onDelete: Cascade)
  source      Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([reviewJobId])
  @@index([sourceId])
  @@map("evidence_snippets")
}
